// 八白五格渲染
// ═══════════════════════════════════════════════════════════════
function renderWuge(d){
  var wg = d.wuge;
  if(!wg.surname || !wg.name1){
    document.getElementById('wugeSec').style.display='none';
    return;
  }
  
  // 如果任何笔画=0 说明字库不全，提示
  var missing = [];
  if(wg.surnameStroke===0) missing.push(wg.surname);
  if(wg.name1Stroke===0) missing.push(wg.name1);
  if(wg.name2 && wg.name2Stroke===0) missing.push(wg.name2);
  
  var h = [];
  
  // 格式说明 + 姓名笔画展示
  h.push('<div class="wg-diagram">');
  h.push('<div class="wg-title-row">');
  h.push('<div class="tline">八白姓名学 · 神乎奇际系统</div>');
  h.push('<div class="tmain">格局：'+wg.pattern+'</div>');
  h.push('</div>');
  
  if(missing.length > 0){
    h.push('<div class="wg-xiong-warn">⚠️ 以下字不在康熙字典内建表中，笔画需人工确认：<strong>'+missing.join('、')+'</strong></div>');
  }
  
  // 姓名+笔画展示
  h.push('<div class="wg-name-block">');
  h.push('<div class="wg-name-col"><div class="wg-name-lbl">姓</div><div class="wg-char">'+wg.surname+'</div><div class="wg-stroke">'+wg.surnameStroke+'劃</div></div>');
  h.push('<div class="wg-name-col"><div class="wg-name-lbl">名1</div><div class="wg-char">'+wg.name1+'</div><div class="wg-stroke">'+wg.name1Stroke+'劃</div></div>');
  if(wg.name2){
    h.push('<div class="wg-name-col"><div class="wg-name-lbl">名2</div><div class="wg-char">'+wg.name2+'</div><div class="wg-stroke">'+wg.name2Stroke+'劃</div></div>');
  }
  h.push('</div>');
  
  // 五格展示
  var grids = [
    {name:'天格', num:wg.tianGe, age:'1-12岁 & 61-72岁', cls:''},
    {name:'人格', num:wg.renGe, age:'13-24岁 & 73-84岁', cls:'ren'},
    {name:'地格', num:wg.diGe, age:'25-36岁 & 85-96岁', cls:''},
    {name:'外格', num:wg.waiGe, age:'37-48岁', cls:''},
    {name:'总格', num:wg.zongGe, age:'49-60岁', cls:'total'}
  ];
  
  h.push('<div class="wg-grid">');
  grids.forEach(function(gr){
    var star = getStarInfo(gr.num);
    h.push('<div class="wg-cell '+gr.cls+'">');
    h.push('<div class="wg-cell-name">'+gr.name+'</div>');
    h.push('<div class="wg-cell-num">'+gr.num+'</div>');
    h.push('<div class="wg-cell-star">'+(star.nm||'')+'</div>');
    h.push('<div class="wg-cell-age">'+gr.age+'</div>');
    h.push('</div>');
  });
  h.push('</div>');
  
  h.push('</div>'); // wg-diagram end
  
  // 凶数检查（总格 + 人格 特别注意）
  var warns = [];
  var xRen = checkXiong(wg.renGe);
  var xZong = checkXiong(wg.zongGe);
  if(xRen) warns.push('<strong>⚠️ 人格 '+wg.renGe+'数</strong>：'+xRen+'（作参考，张科勉老师认为81数无绝对吉凶，名人亦多「凶数」如李登辉34数、戴胜通44数）');
  if(xZong) warns.push('<strong>⚠️ 总格 '+wg.zongGe+'数</strong>：'+xZong+'（仅流年凶数才是真凶，参考即可）');
  
  if(warns.length > 0){
    h.push('<div class="wg-xiong-warn">'+warns.join('<br>')+'</div>');
  }
  
  // 人格 & 总格 详细星座解析
  h.push('<div class="wg-star-detail">');
  h.push('<div class="wg-star-title">⭐ 人格数 <span class="wg-star-num">'+wg.renGe+'</span> · '+getStarInfo(wg.renGe).nm+'</div>');
  var renStar = getStarInfo(wg.renGe);
  h.push('<div class="wg-star-body"><strong style="color:#81C784;">✦ 正面：</strong>'+renStar.pos+'<br>');
  h.push('<strong style="color:#EF9A9A;">⚠ 负面：</strong>'+renStar.neg+'<br>');
  h.push('<strong style="color:var(--gl);">💡 建议：</strong>'+renStar.adv+'<br>');
  if(renStar.reps && renStar.reps !== '—') h.push('<span style="color:var(--t3);font-size:11px;">代表人物：'+renStar.reps+'</span>');
  h.push('</div>');
  h.push('</div>');
  
  if(wg.zongGe !== wg.renGe){
    h.push('<div class="wg-star-detail">');
    h.push('<div class="wg-star-title">🎯 总格数 <span class="wg-star-num">'+wg.zongGe+'</span> · '+getStarInfo(wg.zongGe).nm+'</div>');
    var zongStar = getStarInfo(wg.zongGe);
    h.push('<div class="wg-star-body"><strong style="color:#81C784;">✦ 正面：</strong>'+zongStar.pos+'<br>');
    h.push('<strong style="color:#EF9A9A;">⚠ 负面：</strong>'+zongStar.neg+'<br>');
    h.push('<strong style="color:var(--gl);">💡 建议：</strong>'+zongStar.adv+'<br>');
    if(zongStar.reps && zongStar.reps !== '—') h.push('<span style="color:var(--t3);font-size:11px;">代表人物：'+zongStar.reps+'</span>');
    h.push('</div>');
    h.push('</div>');
  }
  
  // 五格人事说明
  h.push('<div class="wg-star-detail" style="margin-top:12px;">');
  h.push('<div class="wg-star-title">📘 五格掌管人事参考</div>');
  h.push('<div class="wg-star-body" style="font-size:12px;">');
  h.push('<strong style="color:var(--gl);">天格 '+wg.tianGe+'：</strong>父母、长上、思想、功名运，女命看夫婿<br>');
  h.push('<strong style="color:#EF9A9A;">人格 '+wg.renGe+'：</strong>自我内在、人生中心、六亲关系（最核心）<br>');
  h.push('<strong style="color:var(--gl);">地格 '+wg.diGe+'：</strong>部属、家庭、妻子、子女，男命看婚姻<br>');
  h.push('<strong style="color:var(--gl);">外格 '+wg.waiGe+'：</strong>出外运、外缘、社交、意志力、成功运<br>');
  h.push('<strong style="color:var(--gold);">总格 '+wg.zongGe+'：</strong>财运、耐心、情绪、后天健康、老年运');
  h.push('</div>');
  h.push('</div>');
  
  document.getElementById('wugeContent').innerHTML = h.join('');
}
