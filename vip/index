<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>数易命盘分析系统 · Wilson Ooi</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@300;400;600;700;900&family=Noto+Sans+SC:wght@300;400;500;700&family=Cinzel:wght@400;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<style>
:root{
  --navy:#040D1A;--dark:#071628;--mid:#0A1E3D;
  --blue:#1565C0;--light:#2196F3;--pale:#64B5F6;--glow:#90CAF9;
  --gold:#C9A84C;--gl:#F0D080;--gb:#FFE566;--gd:#8B6914;
  --white:#FFF;--t1:#EFF6FF;--t2:#C8E0F4;--t3:#8BB8D8;
  --green:#2ECC71;--red:#EF5350;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:"Noto Sans SC",sans-serif;background:var(--navy);color:var(--t1);min-height:100vh;}
.hdr{background:linear-gradient(90deg,#030810,#071628,#030810);border-bottom:1px solid rgba(201,168,76,.35);padding:14px 24px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;}
.logo{font-family:"Cinzel",serif;font-size:17px;color:var(--gl);font-weight:600;letter-spacing:2px;}
.logo span{font-size:12px;color:var(--t3);display:block;font-family:"Noto Sans SC",sans-serif;font-weight:300;margin-top:2px;letter-spacing:1px;}
.hdr-tag{font-size:12px;color:var(--pale);background:rgba(33,150,243,.1);border:1px solid rgba(33,150,243,.3);padding:4px 14px;border-radius:20px;}

/* INPUT */
.inp-wrap{max-width:660px;margin:0 auto;padding:48px 24px 32px;}
.ititle{font-family:"Noto Serif SC",serif;font-size:clamp(22px,5vw,34px);font-weight:700;text-align:center;color:var(--white);margin-bottom:6px;}
.ititle .g{background:linear-gradient(135deg,var(--gb),var(--gl),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
.isub{text-align:center;font-size:14px;color:var(--t3);margin-bottom:32px;}
.card{background:linear-gradient(135deg,rgba(21,101,192,.18),rgba(33,150,243,.06));border:1px solid rgba(33,150,243,.35);border-radius:22px;padding:32px;}
.lbl{font-size:13px;color:var(--gl);letter-spacing:1px;margin-bottom:8px;display:block;font-weight:600;}
.inp{width:100%;background:rgba(0,0,0,.4);border:1px solid rgba(33,150,243,.28);border-radius:12px;padding:13px 16px;font-size:16px;color:var(--white);font-family:"Noto Sans SC",sans-serif;outline:none;transition:border-color .3s;margin-bottom:18px;}
.inp:focus{border-color:rgba(201,168,76,.55);}
.inp::placeholder{color:var(--t3);}
.dob-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:6px;}
.hint{font-size:12px;color:var(--t3);margin-bottom:16px;}

.bcalc{width:100%;padding:17px;border-radius:60px;background:linear-gradient(135deg,var(--gb),var(--gl),var(--gold));color:var(--navy);font-size:17px;font-weight:700;border:none;cursor:pointer;font-family:"Noto Sans SC",sans-serif;transition:all .3s;box-shadow:0 8px 28px rgba(201,168,76,.35);}
.bcalc:hover{transform:translateY(-2px);box-shadow:0 14px 40px rgba(201,168,76,.5);}

/* LOADING */
.loading{display:none;text-align:center;padding:60px 24px;}
.loading.on{display:block;}
.spin{width:72px;height:72px;margin:0 auto 20px;border-radius:50%;border:3px solid transparent;border-top-color:var(--gold);border-right-color:var(--light);animation:sp 1s linear infinite;}
@keyframes sp{to{transform:rotate(360deg);}}

/* RESULT */
.result{display:none;max-width:980px;margin:0 auto;padding:0 20px 80px;}
.result.on{display:block;}
.actbar{display:flex;gap:10px;margin-bottom:28px;flex-wrap:wrap;justify-content:center;}
.bact{display:flex;align-items:center;gap:8px;padding:11px 22px;border-radius:50px;font-size:14px;font-weight:700;cursor:pointer;border:none;font-family:"Noto Sans SC",sans-serif;transition:all .3s;text-decoration:none;}
.bpdf{background:linear-gradient(135deg,#C0392B,#E74C3C);color:#fff;box-shadow:0 5px 18px rgba(192,57,43,.35);}
.bwa{background:linear-gradient(135deg,#25D366,#2ECC71);color:#fff;box-shadow:0 5px 18px rgba(37,211,102,.35);}
.breset{background:rgba(33,150,243,.12);border:1px solid rgba(33,150,243,.3);color:var(--glow);}
.bact:hover{transform:translateY(-2px);}

/* REPORT */
.report{background:linear-gradient(160deg,#071628,#040D1A);border:1px solid rgba(201,168,76,.18);border-radius:22px;overflow:hidden;}
.rhdr{background:linear-gradient(135deg,rgba(21,101,192,.35),rgba(4,13,26,.9));padding:28px 32px;border-bottom:1px solid rgba(201,168,76,.18);display:flex;align-items:center;gap:20px;flex-wrap:wrap;}
.rav{width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,var(--gold),var(--gd));display:flex;align-items:center;justify-content:center;font-family:"Cinzel",serif;font-size:24px;font-weight:700;color:var(--navy);flex-shrink:0;box-shadow:0 0 0 4px rgba(201,168,76,.2);}
.rname{font-family:"Noto Serif SC",serif;font-size:24px;font-weight:700;color:var(--white);}
.rdate{font-size:13px;color:var(--t3);margin-top:4px;}
.rmast{margin-left:auto;text-align:center;background:rgba(0,0,0,.3);border:1px solid rgba(201,168,76,.3);border-radius:14px;padding:14px 22px;}
.rml{font-size:11px;color:var(--gold);letter-spacing:2px;margin-bottom:4px;}
.rmn{font-family:"Cinzel",serif;font-size:48px;font-weight:700;color:var(--gl);line-height:1;}
.rmname{font-size:13px;color:var(--t2);margin-top:4px;}

/* SECTION */
.sec{padding:26px 30px;border-bottom:1px solid rgba(255,255,255,.05);}
.sec:last-child{border-bottom:none;}
.sttl{display:flex;align-items:center;gap:10px;font-family:"Noto Serif SC",serif;font-size:16px;font-weight:700;color:var(--gl);margin-bottom:18px;padding-bottom:10px;border-bottom:1px solid rgba(201,168,76,.15);}

/* MINGPAN */
.mp{background:rgba(0,0,0,.22);border:1px solid rgba(33,150,243,.18);border-radius:16px;padding:16px 10px;margin-bottom:14px;overflow:hidden;}

/* 13 COMBOS */
.cgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
.citem{background:rgba(0,0,0,.2);border:1px solid rgba(33,150,243,.15);border-radius:10px;padding:12px 13px;border-left:3px solid var(--blue);}
.citem.hi{border-left-color:var(--gold);}
.cnm{font-size:11px;color:var(--t3);margin-bottom:4px;}
.ckey{font-family:"Cinzel",serif;font-size:22px;font-weight:700;color:var(--gl);margin-bottom:4px;}
.cdesc{font-size:12px;color:var(--t2);line-height:1.55;}

/* TRAITS */
.tgrid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;}
.tbox{border-radius:12px;padding:15px;}
.tp{background:rgba(46,204,113,.07);border:1px solid rgba(46,204,113,.22);}
.tn{background:rgba(239,83,80,.07);border:1px solid rgba(239,83,80,.22);}
.tm{background:rgba(255,193,7,.07);border:1px solid rgba(255,193,7,.18);}
.tttl{font-size:12px;font-weight:700;letter-spacing:1px;margin-bottom:9px;}
.tp .tttl{color:#81C784;}.tn .tttl{color:#EF9A9A;}.tm .tttl{color:#FFE082;}
.tbody{font-size:13px;color:var(--t2);line-height:1.85;}

/* MISSING */
.mgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(185px,1fr));gap:10px;}
.mitem{background:rgba(239,83,80,.07);border:1px solid rgba(239,83,80,.2);border-radius:10px;padding:13px;display:flex;gap:10px;}
.mnum{font-family:"Cinzel",serif;font-size:27px;color:#EF9A9A;font-weight:700;opacity:.7;line-height:1;min-width:28px;}
.mname{font-size:13px;color:#E59866;font-weight:600;margin-bottom:3px;}
.mdesc{font-size:12px;color:var(--t2);line-height:1.6;}
.wbox{background:rgba(255,193,7,.07);border:1px solid rgba(255,193,7,.25);border-radius:10px;padding:12px 15px;font-size:13px;color:#FFE082;line-height:1.8;margin-top:11px;}
.wbox strong{color:var(--white);}

/* WUXING */
.wxrow{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin-bottom:13px;}
.wxc{text-align:center;border-radius:12px;padding:13px 6px;}
.wxjin{background:rgba(255,215,0,.07);border:1px solid rgba(255,215,0,.22);}
.wxmu{background:rgba(76,175,80,.07);border:1px solid rgba(76,175,80,.22);}
.wxshui{background:rgba(33,150,243,.09);border:1px solid rgba(33,150,243,.28);}
.wxhuo{background:rgba(239,83,80,.07);border:1px solid rgba(239,83,80,.22);}
.wxtu{background:rgba(255,193,7,.06);border:1px solid rgba(255,193,7,.18);}
.wxch{font-family:"Noto Serif SC",serif;font-size:26px;font-weight:700;margin-bottom:4px;}
.wxjin .wxch{color:#FFD700;}.wxmu .wxch{color:#81C784;}.wxshui .wxch{color:#64B5F6;}.wxhuo .wxch{color:#EF9A9A;}.wxtu .wxch{color:#FFE082;}
.wxns{font-size:11px;color:var(--t3);margin-bottom:4px;}
.wxcnt{font-family:"Cinzel",serif;font-size:22px;font-weight:700;color:var(--white);}
.wxcnt.z{color:var(--red);}
.wxbal{font-size:10px;color:var(--t3);margin-top:2px;}
.btbl{width:100%;border-collapse:collapse;}
.btbl th{font-size:11px;color:var(--gold);letter-spacing:1px;padding:7px 10px;text-align:left;border-bottom:1px solid rgba(201,168,76,.12);}
.btbl td{font-size:13px;padding:9px 10px;border-bottom:1px solid rgba(255,255,255,.04);color:var(--t2);}
.btbl td:first-child{color:var(--t1);font-weight:600;}
.bw{display:flex;align-items:center;gap:7px;}
.btrack{flex:1;height:6px;background:rgba(255,255,255,.07);border-radius:3px;overflow:hidden;}
.bfill{height:100%;border-radius:3px;}
.bdg{display:inline-block;font-size:11px;padding:2px 8px;border-radius:20px;font-weight:600;}
.bok{background:rgba(46,204,113,.15);color:#81C784;}.blow{background:rgba(255,193,7,.15);color:#FFE082;}.bzero{background:rgba(239,83,80,.15);color:#EF9A9A;}.bowang{background:rgba(255,140,0,.18);color:#FFB347;font-weight:700;}

/* LIUNIAN */
.lyhero{background:linear-gradient(135deg,rgba(33,150,243,.14),rgba(33,150,243,.04));border:1px solid rgba(33,150,243,.28);border-radius:14px;padding:20px 24px;margin-bottom:13px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;}
.lybig{font-family:"Cinzel",serif;font-size:50px;font-weight:700;color:var(--pale);line-height:1;}
.lyname{font-family:"Noto Serif SC",serif;font-size:17px;color:var(--glow);margin-top:4px;}
.lytags{display:flex;flex-wrap:wrap;gap:6px;}
.lyt{font-size:11px;padding:3px 10px;border-radius:20px;font-weight:600;}
.lygood{background:rgba(46,204,113,.15);color:#81C784;border:1px solid rgba(46,204,113,.28);}
.lywarn{background:rgba(239,83,80,.15);color:#EF9A9A;border:1px solid rgba(239,83,80,.28);}
.lyinfo{background:rgba(33,150,243,.15);color:var(--glow);border:1px solid rgba(33,150,243,.28);}
.lygold{background:rgba(201,168,76,.15);color:var(--gl);border:1px solid rgba(201,168,76,.28);}
.lynums{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:13px;}
.lynb{background:rgba(0,0,0,.25);border:1px solid rgba(255,255,255,.07);border-radius:10px;padding:12px;text-align:center;}
.lynbl{font-size:11px;color:var(--t3);letter-spacing:1px;margin-bottom:4px;}
.lynbv{font-family:"Cinzel",serif;font-size:18px;color:var(--gl);font-weight:600;}
.lynbc{font-size:10px;color:var(--t3);margin-top:3px;}
.lyad{background:rgba(33,150,243,.07);border:1px solid rgba(33,150,243,.18);border-radius:10px;padding:13px 16px;font-size:14px;color:var(--t2);line-height:1.85;}
.lyad strong{color:var(--white);}

/* PILLARS */
.pgrid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.pil{border-radius:13px;padding:17px;}
.pc{background:rgba(33,150,243,.09);border:1px solid rgba(33,150,243,.22);}
.pl{background:rgba(239,83,80,.09);border:1px solid rgba(239,83,80,.22);}
.pw{background:rgba(201,168,76,.09);border:1px solid rgba(201,168,76,.22);}
.ph{background:rgba(46,204,113,.09);border:1px solid rgba(46,204,113,.22);}
.phdr{display:flex;align-items:center;gap:8px;margin-bottom:8px;}
.pico{font-size:16px;}
.pnm{font-size:13px;font-weight:700;}
.pc .pnm{color:var(--glow);}.pl .pnm{color:#EF9A9A;}.pw .pnm{color:var(--gl);}.ph .pnm{color:#81C784;}
.ptxt{font-size:13px;color:var(--t2);line-height:1.8;}

/* ═══ 八白五格 (WUGE) ═══ */
.wg-diagram{background:linear-gradient(135deg,rgba(7,22,40,.95),rgba(4,13,26,.98));border:1px solid rgba(201,168,76,.3);border-radius:16px;padding:24px 20px;margin-bottom:16px;}
.wg-title-row{text-align:center;margin-bottom:20px;}
.wg-title-row .tline{font-size:12px;color:var(--gold);letter-spacing:2px;margin-bottom:4px;}
.wg-title-row .tmain{font-family:"Noto Serif SC",serif;font-size:18px;color:var(--gl);font-weight:700;}
.wg-name-block{display:flex;justify-content:center;align-items:stretch;gap:20px;margin-bottom:16px;flex-wrap:wrap;}
.wg-name-col{display:flex;flex-direction:column;align-items:center;gap:6px;}
.wg-name-lbl{font-size:11px;color:var(--t3);letter-spacing:1px;}
.wg-char{width:56px;height:56px;background:rgba(0,0,0,.5);border:1.5px solid rgba(201,168,76,.4);border-radius:10px;display:flex;align-items:center;justify-content:center;font-family:"Noto Serif SC",serif;font-size:28px;font-weight:700;color:var(--white);}
.wg-stroke{font-family:"Cinzel",serif;font-size:14px;color:var(--gold);font-weight:700;}
.wg-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;}
.wg-cell{background:rgba(0,0,0,.3);border:1.5px solid rgba(33,150,243,.3);border-radius:12px;padding:14px 8px;text-align:center;position:relative;}
.wg-cell.total{border-color:rgba(201,168,76,.5);background:rgba(201,168,76,.08);}
.wg-cell.ren{border-color:rgba(239,83,80,.45);background:rgba(239,83,80,.08);}
.wg-cell-name{font-size:11px;color:var(--t3);letter-spacing:1px;margin-bottom:6px;}
.wg-cell.total .wg-cell-name{color:var(--gold);}
.wg-cell.ren .wg-cell-name{color:#EF9A9A;}
.wg-cell-num{font-family:"Cinzel",serif;font-size:26px;font-weight:700;color:var(--white);line-height:1;margin-bottom:4px;}
.wg-cell-star{font-size:10px;color:var(--gl);margin-top:3px;line-height:1.3;}
.wg-cell-age{font-size:9px;color:var(--t3);margin-top:2px;}
.wg-xiong-warn{background:rgba(239,83,80,.12);border:1px solid rgba(239,83,80,.3);border-left:3px solid #EF5350;border-radius:8px;padding:10px 14px;margin-top:12px;font-size:12px;color:#EF9A9A;line-height:1.7;}
.wg-star-detail{background:rgba(0,0,0,.25);border:1px solid rgba(201,168,76,.2);border-radius:12px;padding:14px 16px;margin-top:12px;}
.wg-star-title{font-size:13px;font-weight:700;color:var(--gl);margin-bottom:8px;display:flex;align-items:center;gap:8px;}
.wg-star-num{font-family:"Cinzel",serif;font-size:20px;color:var(--gold);}
.wg-star-body{font-size:12px;color:var(--t2);line-height:1.7;}

/* 媒体查询 */
@media(max-width:680px){
  .tgrid,.pgrid{grid-template-columns:1fr;}
  .cgrid{grid-template-columns:1fr 1fr;}
  .wxrow{grid-template-columns:repeat(3,1fr);}
  .rhdr{flex-direction:column;}
  .rmast{margin-left:0;width:100%;}
  .sec{padding:18px 16px;}
  .dob-grid{grid-template-columns:1fr;}
  .wg-grid{grid-template-columns:repeat(3,1fr);}
}
@media(max-width:420px){.cgrid{grid-template-columns:1fr;}}

/* PASSWORD */
.pw-wrap{max-width:420px;margin:0 auto;padding:80px 24px;text-align:center;}
.pw-title{font-family:"Noto Serif SC",serif;font-size:28px;font-weight:700;color:var(--white);margin-bottom:8px;}
.pw-sub{font-size:14px;color:var(--t3);margin-bottom:36px;}
.pw-lock{font-size:56px;margin-bottom:24px;}
.pw-card{background:linear-gradient(135deg,rgba(21,101,192,.18),rgba(33,150,243,.06));border:1px solid rgba(33,150,243,.35);border-radius:22px;padding:32px;}
.pw-inp{width:100%;background:rgba(0,0,0,.45);border:1px solid rgba(33,150,243,.35);border-radius:12px;padding:16px;font-size:24px;color:var(--white);font-family:"Cinzel",serif;outline:none;text-align:center;letter-spacing:8px;margin-bottom:20px;transition:border-color .3s;}
.pw-inp:focus{border-color:rgba(201,168,76,.6);}
.pw-inp::placeholder{font-size:14px;letter-spacing:2px;color:var(--t3);font-family:"Noto Sans SC",sans-serif;}
.pw-btn{width:100%;padding:16px;border-radius:60px;background:linear-gradient(135deg,var(--gb),var(--gl),var(--gold));color:var(--navy);font-size:17px;font-weight:700;border:none;cursor:pointer;font-family:"Noto Sans SC",sans-serif;box-shadow:0 8px 28px rgba(201,168,76,.35);transition:all .3s;}
.pw-btn:hover{transform:translateY(-2px);}
.pw-err{color:#EF9A9A;font-size:14px;margin-top:12px;display:none;}
.pw-err.show{display:block;}
</style>
</head>
<body>
<div class="hdr">
  <div><div class="logo">数字生命信息系统<span>Wilson Ooi · 数易命盘 + 八白姓名</span></div></div>
  <div class="hdr-tag">v2.0 完整整合版</div>
</div>

<!-- PASSWORD -->
<div style="min-height:100vh;background:var(--navy);" id="pwPage"><div class="pw-wrap">
  <div class="pw-lock">🔐</div>
  <h2 class="pw-title">数字生命信息系统</h2>
  <p class="pw-sub">此系统仅限授权学员使用<br>请输入访问密码</p>
  <div class="pw-card">
    <input class="pw-inp" id="pwInp" type="password" placeholder="输入密码" maxlength="10" onkeydown="if(event.key==='Enter')checkPw()">
    <button class="pw-btn" onclick="checkPw()">🔓 进入系统</button>
    <div class="pw-err" id="pwErr">❌ 密码错误，请重试</div>
  </div>
</div></div>

<!-- INPUT -->
<div id="inpPage" style="display:none;min-height:100vh;background:var(--navy);"><div class="inp-wrap">
  <h1 class="ititle">数易<span class="g">命盘分析</span></h1>
  <p class="isub">完整命盘 · 13组合 · 五行 · 流年 · 八白五格 · 姓名生肖</p>
  <div class="card">
    <label class="lbl">👤 中文姓名</label>
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:6px;">
      <div>
        <div style="font-size:11px;color:var(--t3);margin-bottom:5px;letter-spacing:1px;">姓</div>
        <input class="inp" id="iSurname" placeholder="如：陈" style="margin:0;text-align:center;font-size:18px;">
      </div>
      <div>
        <div style="font-size:11px;color:var(--t3);margin-bottom:5px;letter-spacing:1px;">名1（21-40岁）</div>
        <input class="inp" id="iName1" placeholder="如：伟" style="margin:0;text-align:center;font-size:18px;">
      </div>
      <div>
        <div style="font-size:11px;color:var(--t3);margin-bottom:5px;letter-spacing:1px;">名2（41-60岁）</div>
        <input class="inp" id="iName2" placeholder="如：明（可选）" style="margin:0;text-align:center;font-size:18px;">
      </div>
    </div>
    <div style="font-size:11px;color:var(--t3);margin-bottom:16px;">💡 系统自动以康熙字典正体字计算笔画</div>
    <label class="lbl">📅 出生日期</label>
    <div class="dob-grid">
      <input class="inp" id="iDay" placeholder="日" type="number" min="1" max="31" style="margin:0">
      <input class="inp" id="iMon" placeholder="月" type="number" min="1" max="12" style="margin:0">
      <input class="inp" id="iYr" placeholder="如 1999" type="number" min="1900" max="2030" style="margin:0">
    </div>
    <div class="hint">例：01 / 01 / 1999</div>
    <button class="bcalc" onclick="doCalc()">🔮 生成完整命盘报告</button>
  </div>
</div></div>

<!-- LOADING -->
