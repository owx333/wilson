function analyzeCharByRadicals(ch, zodiac){
  var findings = [];
  var roots = CHAR_ROOTS[ch];
  if(!roots) return findings;

  roots.forEach(function(root){
    var def = ROOT_DEFS[root];
    if(!def) return;

    if(def.good && (def.good.includes(zodiac) || def.good.includes('all'))){
      findings.push({type:'good', tag:def.tag, reason: getGoodReason(root, zodiac)});
    }
    if(def.bad && (def.bad.includes(zodiac) || def.bad.includes('all'))){
      findings.push({type:'bad', tag:def.badtag||def.tag, reason: getBadReason(root, zodiac)});
    }
  });
  return findings;
}

