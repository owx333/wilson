// ── 加总至个位数 ──
function R(n){while(n>9){var s=0;String(n).split('').forEach(function(d){s+=parseInt(d);});n=s;}return n;}

// ── 康熙字典笔画计算 (以字典表为准) ──
function getStroke(ch){
  // 先简繁转换
  var tradCh = SIMP_TO_TRAD[ch] || ch;
  // 查字典表
  if(KANGXI_STROKES[tradCh]) return KANGXI_STROKES[tradCh];
  if(KANGXI_STROKES[ch]) return KANGXI_STROKES[ch];
  // 字典里没有就返回0（需人工确认）
  return 0;
}

// ── 八白姓名学五格计算 ──
function computeWuge(surname, name1, name2){
  var s = surname ? getStroke(surname) : 0;
  var n1 = name1 ? getStroke(name1) : 0;
  var n2 = name2 ? getStroke(name2) : 0;
  
  var pattern = '', tianGe=0, renGe=0, diGe=0, waiGe=0, zongGe=0;
  
  if(surname && name1 && name2){
    // 单姓复名
    pattern = '单姓复名';
    tianGe = 1 + s;
    renGe = s + n1;
    diGe = n1 + n2;
    waiGe = 1 + n2;
    zongGe = s + n1 + n2;
  } else if(surname && name1 && !name2){
    // 单姓单名
    pattern = '单姓单名';
    tianGe = 1 + s;
    renGe = s + n1;
    diGe = n1 + 1;
    waiGe = 1 + 1;
    zongGe = s + n1;
  }
  
  return {
    pattern:pattern,
    surnameStroke:s, name1Stroke:n1, name2Stroke:n2,
    tianGe:tianGe, renGe:renGe, diGe:diGe, waiGe:waiGe, zongGe:zongGe,
    surname:surname||'', name1:name1||'', name2:name2||''
  };
}

