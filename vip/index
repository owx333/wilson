// 姓名生肖分析渲染
// ═══════════════════════════════════════════════════════════════
function renderNameAnalysis(d, nameSecEl, naEl) {
  if(!d.surname && !d.name1){ nameSecEl.style.display='none'; return; }

  var zInfo = ZODIAC_INFO[d.zodiac] || {};
  var icon = zInfo.icon || '🌟';
  var fullName = (d.surname||'') + (d.name1||'') + (d.name2||'');
  var allChars = fullName.split('');

  var charData = allChars.map(function(ch){
    return { ch: ch, findings: analyzeCharByRadicals(ch, d.zodiac), stroke: getStroke(ch) };
  });

  var hasFood = false, hasGround = false, hasPosition = false, hasInfluence = false, hasFu = false;
  var isBigZodiac = ['鼠','虎','龙','马'].includes(d.zodiac);

  charData.forEach(function(item){
    item.findings.forEach(function(f){
      if(f.type==='good'){
        if(f.tag==='得食') hasFood = true;
        if(f.tag==='得地') hasGround = true;
        if(f.tag==='得位') hasPosition = true;
        if(f.tag.indexOf('得势')>=0) hasInfluence = true;
        if(f.tag==='得福') hasFu = true;
      }
    });
  });

  var issues = {laolu:[], piaofu:[], wuqi:[], duanfu:[], kefu:[], gudu:[], bound:[], degrade:[], special:[]};
  var LAOLU_CHARS = ['日','阳','白','光','明','昌','晶','晟','晓','辉','耀','旭','昱','昊','旺'];
  var PIAOFU_CHARS = ['霞','梦','露','风','雪','寒','冰','雾','云','飘'];
  var WUQI_CHARS = ['刀','刃','利','刚','剑','锋','刻','矛','戈','伐','戟','兵'];
  var DUANFU_CHARS = ['春','夏','秋','冬','梅','兰','竹','菊','桃','杏'];
  var KEFU_CHARS = ['忠','义','强','凤','淑','顺','勇'];
  var GUDU_CHARS = ['婵','素','莲','燕','孤','寡'];
  var BOUND_CHARS = ['文','义','女','美','英'];

  allChars.forEach(function(ch){
    if(LAOLU_CHARS.includes(ch)){ if(['鼠','狗','蛇'].includes(d.zodiac)) issues.laolu.push(ch);}
    if(PIAOFU_CHARS.includes(ch)) issues.piaofu.push(ch);
    if(WUQI_CHARS.includes(ch)) issues.wuqi.push(ch);
    if(DUANFU_CHARS.includes(ch)) issues.duanfu.push(ch);
    if(KEFU_CHARS.includes(ch)) issues.kefu.push(ch);
    if(GUDU_CHARS.includes(ch)) issues.gudu.push(ch);
    if(BOUND_CHARS.includes(ch)) issues.bound.push(ch);
    if(FORBIDDEN_CHARS.specific[ch]) issues.special.push({char:ch, reason:FORBIDDEN_CHARS.specific[ch]});
    if(d.zodiac==='龙'){
      if(['伟','仁','仲','信','俊','健','弓','张','弦','虫','蛇','蟠'].includes(ch)) issues.degrade.push(ch+'(龙忌)');
    }
  });

  var totalIssues = issues.laolu.length + issues.piaofu.length + issues.wuqi.length +
    issues.duanfu.length + issues.kefu.length + issues.gudu.length +
    issues.bound.length + issues.degrade.length + issues.special.length;

  var goodCount = charData.reduce(function(s,item){
    return s + item.findings.filter(function(f){ return f.type==='good'; }).length;
  }, 0);
  var blessings = [hasFood,hasGround,hasPosition,hasInfluence,hasFu].filter(Boolean).length;
  var score = Math.max(0, Math.min(100, 50 + (blessings*8) + (goodCount*3) - (totalIssues*10)));
  var scoreColor = score>=75?'#2ECC71':score>=50?'#F39C12':'#E74C3C';
  var scoreLabel = score>=75?'整体良好':score>=50?'有待改善':'需要注意';

  var h = [];
  h.push('<div style="background:linear-gradient(135deg,rgba(7,22,40,.95),rgba(4,13,26,.98));border:1px solid rgba(201,168,76,.3);border-radius:16px;padding:20px;margin-bottom:16px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;">');
  h.push('<div style="display:flex;align-items:center;gap:14px;">');
  h.push('<div style="font-size:52px;line-height:1;">' + icon + '</div>');
  h.push('<div>');
  h.push('<div style="font-size:17px;font-weight:700;color:var(--gl);">生肖 ' + d.zodiac + '（五行属' + (zInfo.elem||'') + '）</div>');
  h.push('<div style="font-size:14px;color:var(--white);margin-top:6px;letter-spacing:1px;">「' + fullName + '」</div>');
  h.push('<div style="font-size:11px;color:var(--t3);margin-top:4px;">命占3分（先天）· 名占7分（后天）· 越常用能量越强</div>');
  h.push('</div></div>');
  h.push('<div style="text-align:center;background:rgba(0,0,0,.35);border:1.5px solid ' + scoreColor + '55;border-radius:14px;padding:14px 22px;">');
  h.push('<div style="font-size:10px;color:var(--t3);letter-spacing:1.5px;margin-bottom:4px;">配合指数</div>');
  h.push('<div style="font-size:44px;font-weight:700;color:' + scoreColor + ';line-height:1;">' + score + '</div>');
  h.push('<div style="font-size:11px;color:' + scoreColor + ';margin-top:5px;">' + scoreLabel + '</div>');
  h.push('</div></div>');

  // 五福临门
  h.push('<div style="background:rgba(0,0,0,.2);border:1px solid rgba(201,168,76,.15);border-radius:14px;padding:16px;margin-bottom:16px;">');
  h.push('<div style="font-size:13px;font-weight:700;color:var(--gl);margin-bottom:12px;letter-spacing:.5px;">五福临门检测</div>');
  h.push('<div style="display:grid;grid-template-columns:repeat(5,1fr);gap:8px;">');
  var blessData = [
    {label:'得食', has:hasFood},
    {label:'得地', has:hasGround},
    {label:'得位', has:hasPosition},
    {label:'得势', has:hasInfluence},
    {label:'得福', has:hasFu}
  ];
  blessData.forEach(function(b){
    h.push('<div style="text-align:center;background:' + (b.has?'rgba(46,204,113,.1)':'rgba(239,83,80,.08)') + ';border:1px solid ' + (b.has?'rgba(46,204,113,.3)':'rgba(239,83,80,.2)') + ';border-radius:10px;padding:10px 6px;">');
    h.push('<div style="font-size:18px;">' + (b.has?'✦':'✧') + '</div>');
    h.push('<div style="font-size:12px;font-weight:700;color:' + (b.has?'#81C784':'#EF9A9A') + ';margin:4px 0;">' + b.label + '</div>');
    h.push('<div style="font-size:10px;color:' + (b.has?'#81C784':'#EF9A9A') + ';line-height:1.4;">' + (b.has?'✅':'❌') + '</div>');
    h.push('</div>');
  });
  h.push('</div>');
  
  var insights = [];
  if(!hasFood) insights.push({type:'bad', text:'你不是赚不到钱，是名字没有"食物"，只能靠拼命。'});
  if(!hasGround) insights.push({type:'bad', text:'你有赚钱能力，但名字没有"地基"，所以留不住钱。'});
  if(!hasPosition) insights.push({type:'bad', text: isBigZodiac ? '你是大生肖，名字要有帝王字根才能发挥格局。' : '你是小生肖，名字用大字会扛不住，形成压力。'});
  if(!hasInfluence) insights.push({type:'bad', text:'名字没有"贵人结构"，这辈子最辛苦是没人帮你。'});
  if(!hasFu) insights.push({type:'bad', text:'没有得福结构，人生模式是一直忙、很少享受。'});
  if(blessings >= 4) insights.push({type:'good', text:'五福临门达' + blessings + '项，名字能量结构良好！'});
  else if(blessings >= 2) insights.push({type:'ok', text:'五福命中' + blessings + '项，仍有' + (5-blessings) + '项可以强化。'});

  if(insights.length > 0){
    h.push('<div style="margin-top:12px;display:flex;flex-direction:column;gap:6px;">');
    insights.forEach(function(ins){
      var c = ins.type==='good'?'#81C784':ins.type==='ok'?'#FFE082':'#EF9A9A';
      var ic = ins.type==='good'?'✦':ins.type==='ok'?'◆':'⚠';
      h.push('<div style="font-size:13px;color:' + c + ';line-height:1.7;padding:8px 12px;background:rgba(0,0,0,.2);border-radius:8px;border-left:3px solid ' + c + ';">' + ic + ' ' + ins.text + '</div>');
    });
    h.push('</div>');
  }
  h.push('</div>');

  // 逐字深度拆析
  h.push('<div style="margin-bottom:16px;">');
  h.push('<div style="font-size:13px;font-weight:700;color:var(--gl);margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid rgba(201,168,76,.15);">🔎 逐字深度拆析</div>');

  charData.forEach(function(item){
    var goods = item.findings.filter(function(f){ return f.type==='good'; });
    var bads  = item.findings.filter(function(f){ return f.type==='bad'; });
    var forbReason = FORBIDDEN_CHARS.specific[item.ch];
    var isLaolu  = LAOLU_CHARS.includes(item.ch) && ['鼠','狗','蛇'].includes(d.zodiac);
    var isPiaofu = PIAOFU_CHARS.includes(item.ch);
    var isWuqi   = WUQI_CHARS.includes(item.ch);
    var isDuanfu = DUANFU_CHARS.includes(item.ch);
    var isBound  = BOUND_CHARS.includes(item.ch);
    var isKefu   = KEFU_CHARS.includes(item.ch);
    var isGudu   = GUDU_CHARS.includes(item.ch);

    var hasAnyBad = bads.length>0 || forbReason || isLaolu || isPiaofu || isWuqi || isDuanfu || isBound || isKefu || isGudu;
    var hasAnyGood = goods.length > 0;

    var leftColor = hasAnyGood && !hasAnyBad ? '#2ECC71' : hasAnyBad ? '#E74C3C' : '#334466';
    var bg = hasAnyGood && !hasAnyBad ? 'rgba(46,204,113,.07)' : hasAnyBad ? 'rgba(239,83,80,.07)' : 'rgba(255,255,255,.03)';
    var border = hasAnyGood && !hasAnyBad ? 'rgba(46,204,113,.3)' : hasAnyBad ? 'rgba(239,83,80,.3)' : 'rgba(255,255,255,.08)';

