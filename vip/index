function doCalc(){
  var surname=document.getElementById('iSurname').value.trim();
  var name1=document.getElementById('iName1').value.trim();
  var name2=document.getElementById('iName2').value.trim();
  var name = surname + name1 + name2;
  var day=parseInt(document.getElementById('iDay').value);
  var month=parseInt(document.getElementById('iMon').value);
  var year=parseInt(document.getElementById('iYr').value);
  if(!surname||!name1){alert('请输入姓和名1');return;}
  if(!day||!month||!year||day<1||day>31||month<1||month>12||year<1900){alert('请输入正确的出生日期');return;}
  document.getElementById('inpPage').style.display='none';
  document.getElementById('loading').classList.add('on');
  setTimeout(function(){
    try {
      var data=compute(name,day,month,year,surname,name1,name2);
      renderReport(data);
      document.getElementById('loading').classList.remove('on');
      document.getElementById('resultWrap').classList.add('on');
      document.getElementById('resultWrap').scrollIntoView({behavior:'smooth'});
    } catch(err) {
      document.getElementById('loading').classList.remove('on');
      document.getElementById('inpPage').style.display='block';
      alert('分析时出现错误：' + err.message + '\n\n请截图联系Wilson');
      console.error('Error:', err);
    }
  },900);
}

function doReset(){
  document.getElementById('resultWrap').classList.remove('on');
  document.getElementById('inpPage').style.display='block';
  window.scrollTo({top:0,behavior:'smooth'});
}
