    return '<div style="width:'+size+';height:'+size+';border-radius:50%;background:'+(bg||'rgba(33,150,243,.12)')+';border:2px solid '+(borderColor||'rgba(33,150,243,.5)')+';display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0;">'+
      '<div style="font-size:9px;color:var(--gold);letter-spacing:.5px;">'+lbl+'</div>'+
      '<div style="font-family:\'Cinzel\',serif;font-size:clamp(14px,3.5vw,20px);font-weight:700;color:'+(textColor||'var(--pale)')+';">'+val+'</div></div>';
  };
  var efbox=function(lbl,val){
    return '<div style="background:rgba(201,168,76,.1);border:1.5px solid rgba(201,168,76,.35);border-radius:8px;padding:8px 10px;text-align:center;min-width:52px;">'+
      '<div style="font-size:9px;color:var(--gold);margin-bottom:3px;">'+lbl+'</div>'+
      '<div style="font-family:\'Cinzel\',serif;font-size:clamp(15px,3.5vw,20px);font-weight:700;color:var(--gl);">'+val+'</div></div>';
  };
  var botbox=function(lbl,val){
    return '<div style="background:rgba(0,0,0,.35);border:1.5px solid rgba(33,150,243,.25);border-radius:7px;padding:6px 4px;text-align:center;flex:1;min-width:0;">'+
      '<div style="font-size:8px;color:var(--t3);margin-bottom:2px;">'+lbl+'</div>'+
      '<div style="font-family:\'Cinzel\',serif;font-size:clamp(12px,3vw,17px);font-weight:600;color:var(--t2);">'+val+'</div></div>';
  };
  var star='<div style="font-size:16px;color:var(--gold);flex-shrink:0;">★</div>';
  var xmark='<div style="font-size:20px;color:rgba(33,150,243,.25);flex-shrink:0;">✕</div>';
  var yearDisplay = d.ni===0?'00→5':String(d.ni);

  return '<div style="display:flex;flex-direction:column;gap:12px;align-items:center;width:100%;">'+
  '<div style="display:flex;align-items:center;justify-content:center;gap:8px;width:100%;">'+
    box('日',d.day)+box('月',d.month)+
    circle('Q',d.Q,'58px','var(--gold)','rgba(201,168,76,.12)','var(--gb)')+
    box('纪',d.ji)+box('年',yearDisplay)+
  '</div>'+
  '<div style="display:flex;align-items:center;justify-content:center;gap:8px;width:100%;">'+
    star+box('a',d.a,true)+box('b',d.b,true)+box('c',d.c,true)+box('d',d.d,true)+star+
  '</div>'+
  '<div style="display:flex;align-items:center;justify-content:center;gap:10px;width:100%;">'+
    efbox('e',d.e)+xmark+
    '<div style="width:70px;height:70px;border-radius:50%;background:linear-gradient(135deg,rgba(201,168,76,.25),rgba(201,168,76,.08));border:2.5px solid var(--gold);display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0;">'+
      '<div style="font-family:\'Cinzel\',serif;font-size:clamp(20px,5vw,30px);font-weight:700;color:var(--gb);line-height:1;">'+d.g+'</div>'+
      '<div style="font-size:8px;color:var(--gold);letter-spacing:.5px;">主性格</div></div>'+
    xmark+efbox('f',d.f)+
  '</div>'+
  '<div style="display:flex;align-items:center;justify-content:center;gap:16px;width:100%;">'+
    box('i',d.i)+'<div style="font-size:14px;color:var(--gold);">★</div>'+box('h',d.h)+
  '</div>'+
  '<div style="display:flex;align-items:center;justify-content:center;gap:5px;width:100%;">'+
    '<div style="font-size:13px;color:rgba(33,150,243,.4);flex-shrink:0;">←</div>'+
    botbox('m',d.m2)+botbox('l',d.l)+botbox('k',d.k)+
    '<div style="width:48px;height:48px;border-radius:50%;background:rgba(0,0,0,.4);border:1.5px solid rgba(33,150,243,.5);display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0;">'+
      '<div style="font-size:8px;color:var(--pale);">j</div>'+
      '<div style="font-family:\'Cinzel\',serif;font-size:clamp(13px,3vw,18px);font-weight:700;color:var(--pale);">'+d.j+'</div></div>'+
    botbox('n',d.n2)+botbox('o',d.o)+botbox('p',d.p)+
    '<div style="font-size:13px;color:rgba(33,150,243,.4);flex-shrink:0;">→</div>'+
  '</div>'+
  '</div>';
}

