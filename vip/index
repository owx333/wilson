function compute(name,day,month,year,surname,name1,name2){
  var a=R(day),b=R(month);
  var ji=parseInt(String(year).slice(0,2));
  var ni=parseInt(String(year).slice(2));
  var c=R(ji);
  var d= ni===0 ? 5 : R(ni);
  var e=R(a+b),f=R(c+d),g=R(e+f);
  var h=R(e+g),i=R(f+g),j=R(h+i);
  var k=R(a+e),l=R(b+e),m2=R(k+l);
  var n2=R(c+f),o=R(d+f),p=R(n2+o);
  var Q=R(a+d+g);
  var hid=''+R(e+e)+R(f+f)+R(g+g);
  var all16=[a,b,c,d,e,f,g,h,i,j,k,l,m2,n2,o,p];

  var zodiacs=['鼠','牛','虎','兔','龙','蛇','马','羊','猴','鸡','狗','猪'];
  var zodiac=zodiacs[((year-1900)%12+12)%12];

  var pres=new Set([a,b,c,d,e,f,g]);
  var miss=[];
  for(var x=1;x<=9;x++){if(!pres.has(x))miss.push(x);}

  var wxMap={'金':[1,6],'水':[2,7],'木':[4,9],'火':[3,8],'土':[5]};
  var wx={'金':0,'水':0,'木':0,'火':0,'土':0};
  all16.forEach(function(num){
    Object.keys(wxMap).forEach(function(el){
      if(wxMap[el].includes(num)) wx[el]++;
    });
  });

  var wxCycle=['金','水','木','火','土'];
  var gEl=({'1':'金','6':'金','2':'水','7':'水','4':'木','9':'木','3':'火','8':'火','5':'土'})[String(g)]||'土';

  var lyC=R(20),lyY=R(26),lyA=R(a+b),lyB=R(lyC+lyY),lyG=R(lyA+lyB);

  var md=ND[g]||ND[1];
  var lyd=ND[lyG]||ND[1];

  var c13names=['父基因','母基因','主性格','人生过程(内)','人生过程(外)','子女下属',
    '事业过程①','事业过程②','当下朋友','婚姻过程①','婚姻过程②','未来财富/健康','隐藏号'];
  var c13keys=[
    ''+a+b+c, ''+c+d+f, ''+e+f+g, ''+e+g+h, ''+f+g+i, ''+i+h+j,
    ''+a+e+k, ''+b+e+l, ''+k+l+m2, ''+c+f+n2, ''+d+f+o, ''+n2+o+p, hid
  ];
  var c13=c13names.map(function(nm,idx){
    var key=c13keys[idx];
    var rev=key.split('').reverse().join('');
    var hi=idx===2;
    return {nm:nm, key:key, rev:rev, hi:hi};
  });

  var inner_num = R(g + e + f);
  var subcon_num = R(g + a + d);

  // ═══ 八白姓名学五格 ═══
  var wuge = computeWuge(surname, name1, name2);

  return {
    name:name, surname:surname||'', name1:name1||'', name2:name2||'',
    zodiac:zodiac, day:day, month:month, year:year, ji:ji, ni:ni,
    a:a,b:b,c:c,d:d,e:e,f:f,g:g,h:h,i:i,j:j,k:k,l:l,m2:m2,n2:n2,o:o,p:p,
    Q:Q, hid:hid, all16:all16, pres:pres, miss:miss, wx:wx,
    gEl:gEl,
    lyA:lyA,lyB:lyB,lyG:lyG, md:md, lyd:lyd,
    wxMap:wxMap, c13:c13, lyC:lyC, lyY:lyY,
    inner_num:inner_num, subcon_num:subcon_num,
    wuge:wuge
  };
}

